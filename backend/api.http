# Register Route

POST http://localhost:8080/register HTTP/1.1
Content-Type: application/json

{
    "name" : "user1",
    "username" : "user1",
    "email": "user1@gmail.com",
    "password" : "user1"
}

###

# Login Route
POST http://localhost:8080/login HTTP/1.1
Content-Type: application/json

{
    "email" : "user@gmail.com",
    "password" : "user"
}

###


# Get User and Profile Detailes Route
GET http://localhost:8080/get_user_and_profile HTTP/1.1
Content-Type:  application/json

{
 "token": "52d6fdca4e9f68d4a1bc8e9725aa24a8edcb1ffdb6c156a12aac92b851c116b1"  
}

###

# Update User Detailes Route
POST http://localhost:8080/update_profile HTTP/1.1
Content-Type: application/json

{
    "token": "52d6fdca4e9f68d4a1bc8e9725aa24a8edcb1ffdb6c156a12aac92b851c116b1" , 
    "email": "user@gmail.com",
    "username" : "user"
}


